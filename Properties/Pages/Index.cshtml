@{
    ViewData["Title"] = "Twisted Hollow Prism Dome Calculator";
}

<h2>Volume Calculator</h2>

<form method="post" asp-action="Calculate">
    <label>Inner Area:</label>
    <input type="number" step="any" name="Ainner" required /><br />

    <label>Outer Area:</label>
    <input type="number" step="any" name="Aouter" required /><br />

    <label>Height:</label>
    <input type="number" step="any" name="h" required /><br />

    <label>Deformation Constant (k):</label>
    <input type="number" step="any" name="k" required /><br />

    <label>Twist Angle (degrees):</label>
    <input type="number" step="any" name="theta" required /><br />

    <button type="submit">Calculate</button>
</form>

@if (ViewBag.Result != null)
{
    <h3>Volume: @ViewBag.Result</h3>
}